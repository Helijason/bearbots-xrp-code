{
  "AKit IO Interface": {
    "prefix": "akio",
    "description": "AdvantageKit IO interface with @AutoLog inputs",
    "body": [
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import org.littletonrobotics.junction.AutoLog;",
      "",
      "public interface ${TM_FILENAME_BASE} {",
      "  @AutoLog",
      "  static class ${TM_FILENAME_BASE}Inputs {",
      "    public double ${1:fieldName} = ${2:0.0};",
      "  }",
      "",
      "  default void updateInputs(${TM_FILENAME_BASE}Inputs inputs) {}",
      "",
      "  default void ${3:methodName}(${4:double value}) {}",
      "}"
    ]
  },
  "AKit IO XRP Servo Implementation": {
    "prefix": "akioimpl-xrp-servo",
    "description": "AdvantageKit XRP servo IO implementation",
    "body": [
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.wpilibj.xrp.XRPServo;",
      "import static frc.robot.Constants.${3:SubsystemName}Hardware.*;",
      "",
      "public class ${TM_FILENAME_BASE} implements ${3:SubsystemName}IO {",
      "  private final XRPServo servo = new XRPServo(${4:kServoChannel});",
      "",
      "  private double ${1:commandedAngleDeg} = ${2:0.0};",
      "",
      "  @Override",
      "  public void updateInputs(${3:SubsystemName}IOInputs inputs) {",
      "    inputs.${1:commandedAngleDeg} = ${1:commandedAngleDeg};",
      "  }",
      "",
      "  @Override",
      "  public void ${5:setAngle}(double ${6:angleDeg}) {",
      "    ${1:commandedAngleDeg} = ${6:angleDeg};",
      "    servo.setAngle(${1:commandedAngleDeg});",
      "  }",
      "}"
    ]
  },
  "AKit IO XRP Motor Implementation": {
    "prefix": "akioimpl-xrp-motor",
    "description": "AdvantageKit XRP DC motor IO implementation",
    "body": [
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "import edu.wpi.first.wpilibj.xrp.XRPMotor;",
      "import static frc.robot.Constants.${3:SubsystemName}Hardware.*;",
      "",
      "public class ${TM_FILENAME_BASE} implements ${3:SubsystemName}IO {",
      "  private final XRPMotor motor = new XRPMotor(${4:kMotorChannel});",
      "",
      "  private double ${1:appliedVolts} = ${2:0.0};",
      "",
      "  @Override",
      "  public void updateInputs(${3:SubsystemName}IOInputs inputs) {",
      "    inputs.${1:appliedVolts} = ${1:appliedVolts};",
      "  }",
      "",
      "  @Override",
      "  public void ${5:setVoltage}(double ${6:volts}) {",
      "    ${1:appliedVolts} = ${6:volts};",
      "    motor.set(${1:appliedVolts} / RobotController.getBatteryVoltage());",
      "  }",
      "}"
    ]
  },
  "AKit IO Sim Implementation": {
    "prefix": "akioimpl-sim",
    "description": "AdvantageKit sim IO implementation (no hardware)",
    "body": [
      "package frc.robot.subsystems.${TM_DIRECTORY/^.*[\\/\\\\]([^\\/\\\\]+)$/$1/};",
      "",
      "public class ${TM_FILENAME_BASE} implements ${2:SubsystemName}IO {",
      "  private double ${1:commandedAngleDeg} = ${3:0.0};",
      "",
      "  @Override",
      "  public void updateInputs(${2:SubsystemName}IOInputs inputs) {",
      "    inputs.${1:commandedAngleDeg} = ${1:commandedAngleDeg};",
      "  }",
      "",
      "  @Override",
      "  public void ${4:setAngle}(double ${5:angleDeg}) {",
      "    ${1:commandedAngleDeg} = ${5:angleDeg};",
      "  }",
      "}"
    ]
  },
  "AKit Subsystem": {
    "prefix": "aksubsystem",
    "description": "BearBots SubsystemBase with goal enum and logging",
    "body": [
      "package frc.robot.subsystems;",
      "",
      "import edu.wpi.first.wpilibj2.command.Command;",
      "import edu.wpi.first.wpilibj2.command.SubsystemBase;",
      "import org.littletonrobotics.junction.AutoLogOutput;",
      "",
      "public class ${1:MyClass} extends SubsystemBase {",
      "",
      "    public enum ${1:My}Goal {",
      "        ${2:DEFAULT}",
      "    }",
      "",
      "    @AutoLogOutput",
      "    private ${1:My}Goal goal = ${1:My}Goal.${2:DEFAULT};",
      "",
      "    public ${1:MyClass}() {",
      "        // Configure hardware here",
      "    }",
      "",
      "    @Override",
      "    public void periodic() {",
      "        // Read sensors, log data, apply goal to hardware",
      "    }",
      "",
      "    public void setGoal(${1:My}Goal newGoal) {",
      "        goal = newGoal;",
      "    }",
      "",
      "    public Command setGoalCommand(${1:My}Goal newGoal) {",
      "        return runOnce(() -> setGoal(newGoal));",
      "    }",
      "",
      "    public void stop() {",
      "        // Return to safe state",
      "    }",
      "}"
    ]
  }
}
